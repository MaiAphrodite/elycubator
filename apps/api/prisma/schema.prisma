// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  devices   Device[]
  createdAt DateTime @default(now())
}

model Device {
  id          String   @id @default(uuid()) // Unique identifier from Elysia
  macAddress  String   @unique // Hardware identifier from Wokwi/ESP32
  pairingCode String?  @unique // 6-digit code for the user to claim
  isClaimed   Boolean  @default(false)
  
  nickname    String?
  userId      String?
  owner       User?    @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  telemetry   Telemetry[]
  settings    Settings?
}

model Settings {
  id               String   @id @default(uuid())
  deviceId         String   @unique
  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  targetTemp       Float    @default(37.5)
  targetHumidity   Float    @default(55.0)
  estimatedHatch   DateTime? 
  
  updatedAt        DateTime @updatedAt
}

model Telemetry {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  temperature Float?
  humidity    Float?
  o2Level     Float?
  
  timestamp   DateTime @default(now())
}
