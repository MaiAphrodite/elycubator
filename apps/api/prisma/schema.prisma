generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  devices   Device[]
  createdAt DateTime @default(now())
}

model Device {
  id          String   @id @default(uuid())
  macAddress  String   @unique
  pairingCode String?  @unique
  isClaimed   Boolean  @default(false)

  nickname    String?
  userId      String?
  owner       User?    @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  telemetry   Telemetry[]
  settings    Settings?
}

model Settings {
  id               String   @id @default(uuid())
  deviceId         String   @unique
  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  targetTemp       Float    @default(37.5)
  targetHumidity   Float    @default(55.0)

  tempKp           Float    @default(2.0)
  tempKi           Float    @default(0.5)
  tempKd           Float    @default(1.0)

  humidKp          Float    @default(1.5)
  humidKi          Float    @default(0.3)
  humidKd          Float    @default(0.5)

  turnIntervalHrs  Int      @default(4)
  turnAngle        Int      @default(90)
  servoTrigger     Boolean  @default(false)

  lampEnabled      Boolean  @default(true)
  fanEnabled       Boolean  @default(true)

  updatedAt        DateTime @updatedAt
}

model Telemetry {
  id          String   @id @default(uuid())
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  temperature Float?
  humidity    Float?

  lampDuty    Float?
  fanDuty     Float?
  servoAngle  Float?

  timestamp   DateTime @default(now())
}
